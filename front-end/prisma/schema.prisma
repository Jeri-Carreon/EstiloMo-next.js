generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation("accounts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Counter {
  id    String @id
  value Int
}

model User {
  id            String    @id @default(cuid())
  userCode      String    @unique
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  password      String
  firstName     String
  lastName      String
  lockedUntil   DateTime?
  loginAttempts Int       @default(0)
  mobileNumber  String    @db.VarChar(11)
  role          Role      @default(CUSTOMER)
  isActive      Boolean   @default(true)

  accounts Account[] @relation("accounts")
  sessions Session[]
  barber   Barber?
  customer Customer?
  reviews  Review[]
  services Service[] @relation("StaffServices")
}

model Customer {
  id            String       @id @default(cuid())
  customerCode  String       @unique
  firstName     String
  lastName      String
  email         String?      @unique
  mobileNumber  String       @db.VarChar(11)
  customerType  CustomerType @default(CASUAL)
  loyaltyPoints Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  isActive      Boolean      @default(true)

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  appointments Appointment[]
  loyaltyCards LoyaltyCard[]
}

model Barber {
  id           String @id @default(cuid())
  barberCode   String @unique
  firstName    String
  lastName     String
  mobileNumber String
  email        String

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  appointments Appointment[]
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
}

model ContactUsMessages {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  message   String?
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  service   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Review")
}

model Appointment {
  id              String            @id @default(cuid())
  appointmentCode String            @unique
  scheduledAt     DateTime
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  barberId String
  barber   Barber @relation(fields: [barberId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
}

model LoyaltyCard {
  id         String   @id @default(cuid())
  stars      Int      @default(0)
  status     Status   @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Service {
  id               String           @id @default(cuid())
  serviceCode      String           @unique
  name             String
  description      String?
  category         ServiceCategory?
  durationMinutes  Int
  price            Decimal          @db.Decimal(10, 2)
  isAvailable      Boolean          @default(true)
  bufferBefore     Int              @default(0)
  bufferAfter      Int              @default(0)
  requiresApproval Boolean          @default(false)
  cancellationFee  Decimal?         @db.Decimal(10, 2)
  totalBookings    Int              @default(0)
  totalRevenue     Decimal          @default(0) @db.Decimal(12, 2)
  isFeatured       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  appointments  Appointment[]
  assignedStaff User[]        @relation("StaffServices")
}

enum Role {
  CUSTOMER
  OWNER
  RECEPTIONIST
  BARBER
}

enum CustomerType {
  CASUAL
  REGULAR
}

enum Status {
  ACTIVE
  COMPLETED
}

enum ServiceCategory {
  SIGNATURE_HAIRCUT
  KIDS_HAIRCUT
  SHAVE
  SCALP_MASSAGE
}

enum AppointmentStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
  NOSHOW
}
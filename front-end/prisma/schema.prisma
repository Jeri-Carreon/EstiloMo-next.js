generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation("accounts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Counter {
  id    String @id
  value Int
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  password      String
  firstName     String
  lastName      String
  lockedUntil   DateTime?
  loginAttempts Int           @default(0)
  mobileNumber  String        @db.VarChar(11)
  role          Role          @default(CUSTOMER)
  emailVerified Boolean       @default(false)
  userCode      String        @unique
  isActive      Boolean       @default(true)
  accounts      Account[]     @relation("accounts")
  barber        Barber?
  customer      Customer?
  reviews       Review[]
  securityLogs  SecurityLog[]
  sessions      Session[]
}

model Customer {
  userId              String?               @unique
  customerType        CustomerType          @default(CASUAL)
  createdAt           DateTime              @default(now())
  email               String?               @unique
  firstName           String
  id                  String                @id @default(uuid())
  lastName            String
  loyaltyPoints       Int                   @default(0)
  mobileNumber        String                @db.VarChar(11)
  updatedAt           DateTime              @updatedAt
  customerCode        String                @unique
  isActive            Boolean               @default(true)
  appointments        Appointment[]
  user                User?                 @relation(fields: [userId], references: [id])
  loyaltyCards        LoyaltyCard?
  LoyaltyCardActivity LoyaltyCardActivity[]
  sales               Sale[]
}

model Barber {
  id               String           @id @default(cuid())
  barberCode       String           @unique
  firstName        String
  lastName         String
  mobileNumber     String
  email            String
  userId           String           @unique
  appointments     Appointment[]
  user             User             @relation(fields: [userId], references: [id])
  absence          BarberAbsent[]
  schedules        BarberSchedule[]
  sales            Sale[]
  assignedServices Service[]        @relation("StaffServices")
}

model BarberSchedule {
  id        String   @id @default(cuid())
  barberId  String
  dayOfWeek Int
  startTime Int
  endTime   Int
  isDayOff  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
}

model BarberAbsent {
  id        String   @id @default(cuid())
  barberId  String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, date])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
}

model VerificationToken {
  token   String   @unique
  expires DateTime
  email   String
  id      String   @id @default(cuid())
}

model ContactUsMessages {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  message   String?
  createdAt DateTime @default(now())
}

model Review {
  id            String       @id @default(cuid())
  service       String
  rating        Int
  comment       String?
  createdAt     DateTime     @default(now())
  userId        String
  appointmentId String?      @unique
  isAnonymous   Boolean      @default(false)
  isVisible     Boolean      @default(false)
  saleId        String?      @unique
  status        ReviewStatus @default(PENDING)
  updatedAt     DateTime     @updatedAt
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  sale          Sale?        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Review")
}

model Appointment {
  id                  String                @id @default(cuid())
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  customerId          String
  serviceId           String
  appointmentCode     String                @unique
  barberId            String
  status              AppointmentStatus     @default(PENDING)
  appointmentDate     DateTime
  endMinutes          Int
  startMinutes        Int
  saleId              String?
  source              AppointmentSource     @default(BOOKING)
  reminderSent        Boolean               @default(false)
  afterServicePhotos  AfterServicePhoto[]
  barber              Barber                @relation(fields: [barberId], references: [id])
  customer            Customer              @relation(fields: [customerId], references: [id])
  sale                Sale?                 @relation(fields: [saleId], references: [id])
  service             Service               @relation(fields: [serviceId], references: [id])
  LoyaltyCardActivity LoyaltyCardActivity[]
  payment             Payment?
  review              Review?

  @@index([customerId])
  @@index([serviceId])
  @@index([barberId])
  @@index([saleId])
}

model AppointmentSetting {
  id                 String   @id @default(cuid())
  bookingCutoffHours Int      @default(1)
  pendingCheckoutExpirationMinutes Int @default(15)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AfterServicePhoto {
  id            String      @id @default(cuid())
  appointmentId String
  imageUrl      String
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model Sale {
  id                  String                @id @default(cuid())
  saleCode            String                @unique
  customerId          String
  barberId            String?
  source              SaleSource            @default(WALKIN)
  status              SaleStatus            @default(PENDING)
  downPaymentStatus   String                @default("PENDING")        
  subtotal            Decimal               @default(0) @db.Decimal(10, 2)
  discount            Decimal               @default(0) @db.Decimal(10, 2)
  pwdDiscount         Boolean               @default(false)
  pwdId               String?
  specialDiscountType String?
  vatExempt           Boolean               @default(false)
  vatAmount           Decimal               @default(0) @db.Decimal(10, 2)
  totalAmount         Decimal               @default(0) @db.Decimal(10, 2)
  checkoutExpiresAt   DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  cancelReason        String?
  appointments        Appointment[]
  LoyaltyCardActivity LoyaltyCardActivity[]
  payment             Payment?
  reviews             Review?
  barber              Barber?               @relation(fields: [barberId], references: [id])
  customer            Customer              @relation(fields: [customerId], references: [id])
  items               SaleItem[]

  @@index([customerId])
  @@index([barberId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  serviceId String
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id])

  @@index([saleId])
  @@index([serviceId])
}

model Payment {
  id                        String         @id @default(cuid())
  appointmentId             String?        @unique
  amount                    Decimal        @db.Decimal(10, 2)
  downPayment               Decimal        @default(0) @db.Decimal(10, 2)
  method                    PaymentMethod?
  status                    PaymentStatus  @default(PENDING)
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  discount                  Decimal        @default(0) @db.Decimal(10, 2)
  pwdDiscount               Boolean        @default(false)
  pwdId                     String?
  specialDiscountType       String?
  vatExempt                 Boolean        @default(false)
  vatAmount                 Decimal        @default(0) @db.Decimal(10, 2)
  paymentCode               String?        @unique
  saleId                    String?        @unique
  paymongoCheckoutSessionId String?        @unique
  paymongoPaymentId         String?
  paymongoCheckoutUrl       String?
  paymongoPaymentIntentId   String?        @unique
  screenshotUrl             String?
  gcashRefNo                String?
  appointment               Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  sale                      Sale?          @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model LoyaltyCard {
  id                 String   @id @default(cuid())
  stars              Int      @default(0)
  status             Status   @default(ACTIVE)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  customerId         String   @unique(map: "loyaltycard_customerid_key")
  fiveRewardRedeemed Boolean  @default(false)
  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model LoyaltyCardSetting {
  id                            String   @id @default(cuid())
  stickersPerTransaction        Int      @default(1)
  fiveStickerReward             String   @default("50% Off")
  tenStickerReward              String   @default("100% Off")
  fiftyPercentStickerThreshold  Int      @default(5)
  freeStickerThreshold          Int      @default(10)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model LoyaltyCardActivity {
  id            String       @id @default(cuid())
  customerName  String
  message       String
  createdAt     DateTime     @default(now())
  customerId    String?
  serviceId     String?
  appointmentId String?
  rewardUsed    String       @default("NONE")
  saleId        String?
  stickerNumber Int?
  Appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  Sale          Sale?        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  Customer      Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "loyaltycardactivity_customerid_fkey")
  Service       Service?     @relation(fields: [serviceId], references: [id], onUpdate: NoAction, map: "loyaltycardactivity_serviceid_fkey")

  @@index([appointmentId])
  @@index([customerId])
  @@index([saleId])
}

model Service {
  id                  String                @id @default(cuid())
  name                String
  description         String?
  category            ServiceCategory?
  durationMinutes     Int
  price               Decimal               @db.Decimal(10, 2)
  isAvailable         Boolean               @default(true)
  requiresApproval    Boolean               @default(false)
  cancellationFee     Decimal?              @db.Decimal(10, 2)
  totalBookings       Int                   @default(0)
  totalRevenue        Decimal               @default(0) @db.Decimal(12, 2)
  isFeatured          Boolean               @default(false)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  serviceCode         String                @unique
  sortOrder           Int                   @default(0)
  imageUrl            String?
  appointments        Appointment[]
  LoyaltyCardActivity LoyaltyCardActivity[]
  saleItems           SaleItem[]
  assignedStaff       Barber[]              @relation("StaffServices")
}

model SecurityLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  section   String
  action    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([section])
  @@index([createdAt])
}

model ChatbotSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  response  String
  options   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AIReportLog {
  id              String   @id @default(cuid())
  dateFrom        DateTime
  dateTo          DateTime
  reportType      String
  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  inputCostUSD    Decimal  @db.Decimal(12, 4)
  outputCostUSD   Decimal  @db.Decimal(12, 4)
  totalCostUSD    Decimal  @db.Decimal(12, 4)
  exchangeRatePHP Decimal  @db.Decimal(10, 4)
  totalCostPHP    Decimal  @db.Decimal(12, 4)
  generatedBy     String?
  generatedAt     DateTime @default(now())

  @@index([generatedAt])
  @@index([generatedBy])
  @@index([reportType])
}

model AIChatbotLog {
  id              String   @id @default(cuid())
  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  inputCostUSD    Decimal  @db.Decimal(12, 4)
  outputCostUSD   Decimal  @db.Decimal(12, 4)
  totalCostUSD    Decimal  @db.Decimal(12, 4)
  exchangeRatePHP Decimal  @db.Decimal(10, 4)
  totalCostPHP    Decimal  @db.Decimal(12, 4)
  userId          String?
  messagePreview  String?
  responsePreview String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([model])
  @@index([userId])
}

enum ReviewStatus {
  PENDING
  COMPLETED
  REJECTED
  HIDDEN
}

enum PaymentMethod {
  GCASH
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  REJECTED
  PARTIAL
}

enum downPaymentStatus {
  WALKIN
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}
enum SaleSource {
  BOOKING
  WALKIN
}

enum SaleStatus {
  PENDING
  PAID
  PARTIAL
  CANCELLED
  REFUNDED
}

enum AppointmentSource {
  BOOKING
  WALKIN
}

enum Role {
  CUSTOMER
  OWNER
  RECEPTIONIST
  BARBER
}

enum CustomerType {
  CASUAL
  REGULAR
}

enum AppointmentStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
  NOSHOW
  REJECTED
}

enum Status {
  ACTIVE
  COMPLETED
}

enum ServiceCategory {
  SIGNATURE_HAIRCUT
  KIDS_HAIRCUT
  SHAVE
  SCALP_MASSAGE
}

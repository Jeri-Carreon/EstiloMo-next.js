generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation("accounts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Counter {
  id    String @id
  value Int
}

model User {
  id            String    @id @default(cuid())
  userCode      String    @unique
  
  email         String    @unique
  emailVerified Boolean   @default(false)
  email         String    @unique
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  password      String
  firstName     String
  lastName      String
  lockedUntil   DateTime?
  loginAttempts Int       @default(0)
  mobileNumber  String    @db.VarChar(11)
  role          Role      @default(CUSTOMER)
  emailVerified Boolean   @default(false)
  userCode      String    @unique
  isActive      Boolean   @default(true)
  accounts      Account[] @relation("accounts")
  Barber        Barber?
  customer      Customer?
  reviews       Review[]
  sessions      Session[]
  services      Service[] @relation("StaffServices")

  reviews       Review[]

  customer      Customer?
  barber        Barber?

  services       Service[]  @relation("StaffServices")
}

enum Role {
  CUSTOMER
  OWNER
  RECEPTIONIST
  BARBER
}

model Customer {
  userId        String?       @unique
  customerType  CustomerType  @default(CASUAL)
  createdAt     DateTime      @default(now())
  email         String?       @unique
  firstName     String
  id            String        @id @default(cuid())
  lastName      String
  loyaltyPoints Int           @default(0)
  mobileNumber  String        @db.VarChar(11)
  updatedAt     DateTime      @updatedAt
  customerCode  String        @unique
  isActive      Boolean       @default(true)
  id            String   @id @default(cuid())
  customerCode  String   @unique
  firstName     String
  lastName      String
  email         String?  @unique
  mobileNumber  String   @db.VarChar(11)

  customerType  CustomerType @default(CASUAL)

  loyaltyPoints Int @default(0)

  // Optional link to login account
  userId        String? @unique
  user          User? @relation(fields: [userId], references: [id])

  appointments  Appointment[]
  user          User?         @relation(fields: [userId], references: [id])
  loyaltyCards  LoyaltyCard[]
}

model Barber {
  id            String @id @default(cuid())
  barberCode    String @unique

  firstName     String
  lastName      String
  mobileNumber  String
  email         String

  userId        String @unique
  user          User @relation(fields: [userId], references: [id])

  appointments  Appointment[]
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
}

model VerificationToken {
  token   String   @unique
  expires DateTime
  email   String
  id      String   @id @default(cuid())
}

model ContactUsMessages {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  message   String?
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  service   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Review")
}

enum AppointmentStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
  NOSHOW
}

model Appointment {
  id              String            @id @default(cuid())
  scheduledAt     DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  customerId      String
  serviceId       String
  appointmentCode String            @unique
  barberId        String
  status          AppointmentStatus @default(PENDING)
  Barber          Barber            @relation(fields: [barberId], references: [id])
  customer        Customer          @relation(fields: [customerId], references: [id])
  service         Service           @relation(fields: [serviceId], references: [id])
}

model LoyaltyCard {
  id         String   @id @default(cuid())
  stars      Int      @default(0)
  status     Status   @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Service {
  id               String           @id @default(cuid())
  name             String
  description      String?
  category         ServiceCategory?
  durationMinutes  Int
  price            Decimal          @db.Decimal(10, 2)
  isAvailable      Boolean          @default(true)
  bufferBefore     Int              @default(0)
  bufferAfter      Int              @default(0)
  requiresApproval Boolean          @default(false)
  cancellationFee  Decimal?         @db.Decimal(10, 2)
  totalBookings    Int              @default(0)
  totalRevenue     Decimal          @default(0) @db.Decimal(12, 2)
  isFeatured       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  serviceCode      String           @unique
  appointments     Appointment[]
  assignedStaff    User[]           @relation("StaffServices")
}

model Barber {
  id           String        @id
  barberCode   String        @unique
  firstName    String
  lastName     String
  mobileNumber String
  email        String
  userId       String        @unique
  Appointment  Appointment[]
  User         User          @relation(fields: [userId], references: [id])
}

model Counter {
  id    String @id
  value Int
}

enum Role {
  CUSTOMER
  OWNER
  RECEPTIONIST
  BARBER
}

enum CustomerType {
  CASUAL
  REGULAR
  id              String   @id @default(cuid())
  appointmentCode String   @unique

  barberId        String
  barber          Barber   @relation(fields: [barberId], references: [id])

  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])

  serviceId       String
  service         Service  @relation(fields: [serviceId], references: [id])

  scheduledAt     DateTime
  status          AppointmentStatus @default(PENDING)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum Status {
  ACTIVE
  COMPLETED
}

enum ServiceCategory {
  SIGNATURE_HAIRCUT
  KIDS_HAIRCUT
  SHAVE
  SCALP_MASSAGE
}

enum AppointmentStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
  NOSHOW
}

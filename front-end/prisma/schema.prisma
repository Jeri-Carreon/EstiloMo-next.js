generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation("accounts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Counter {
  id    String @id
  value Int
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  password      String
  firstName     String
  lastName      String
  lockedUntil   DateTime?
  loginAttempts Int       @default(0)
  mobileNumber  String    @db.VarChar(11)
  role          Role      @default(CUSTOMER)
  emailVerified Boolean   @default(false)
  userCode      String    @unique
  isActive      Boolean   @default(true)
  accounts      Account[] @relation("accounts")
  barber        Barber?
  customer      Customer?
  reviews       Review[]
  sessions      Session[]
}

model Customer {
  userId        String?       @unique
  customerType  CustomerType  @default(CASUAL)
  createdAt     DateTime      @default(now())
  email         String?       @unique
  firstName     String
  id            String        @id @default(cuid())
  lastName      String
  loyaltyPoints Int           @default(0)
  mobileNumber  String        @db.VarChar(11)
  updatedAt     DateTime      @updatedAt
  customerCode  String        @unique
  isActive      Boolean       @default(true)
  appointments  Appointment[]
  user          User?         @relation(fields: [userId], references: [id])
  loyaltyCards  LoyaltyCard[]
}

model Barber {
  id               String           @id @default(cuid())
  barberCode       String           @unique
  firstName        String
  lastName         String
  mobileNumber     String
  email            String
  userId           String           @unique
  appointments     Appointment[]
  user             User             @relation(fields: [userId], references: [id])
  absence          BarberAbsent[]
  schedules        BarberSchedule[]
  assignedServices Service[]        @relation("StaffServices")
}

model BarberSchedule {
  id        String   @id @default(cuid())
  barberId  String
  dayOfWeek Int
  startTime Int
  endTime   Int
  isDayOff  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
}

model BarberAbsent {
  id        String   @id @default(cuid())
  barberId  String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, date])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
}

model VerificationToken {
  token   String   @unique
  expires DateTime
  email   String
  id      String   @id @default(cuid())
}

model ContactUsMessages {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  message   String?
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  service   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Review")
}

model Appointment {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  customerId      String
  serviceId       String
  appointmentCode String            @unique
  barberId        String
  status          AppointmentStatus @default(PENDING)
  appointmentDate DateTime
  endMinutes      Int
  startMinutes    Int
  afterServicePhotos AfterServicePhoto[]

  barber   Barber   @relation(fields: [barberId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  payment  Payment?
}

model AfterServicePhoto {
  id            String      @id @default(cuid())
  appointmentId String
  imageUrl      String
  createdAt     DateTime    @default(now())

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model Payment {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  downPayment   Decimal       @db.Decimal(10, 2)
  method        PaymentMethod @default(GCASH)
  status        PaymentStatus @default(PENDING)
  screenshotUrl String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

enum PaymentMethod {
  GCASH
  PAY_AT_SHOP
}

enum PaymentStatus {
  PENDING
  PAID
  REJECTED
}

model LoyaltyCard {
  id         String   @id @default(cuid())
  stars      Int      @default(0)
  status     Status   @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Service {
  id               String           @id @default(cuid())
  name             String
  description      String?
  category         ServiceCategory?
  durationMinutes  Int
  price            Decimal          @db.Decimal(10, 2)
  isAvailable      Boolean          @default(true)
  requiresApproval Boolean          @default(false)
  cancellationFee  Decimal?         @db.Decimal(10, 2)
  totalBookings    Int              @default(0)
  totalRevenue     Decimal          @default(0) @db.Decimal(12, 2)
  isFeatured       Boolean          @default(false)
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  serviceCode      String           @unique
  appointments     Appointment[]
  assignedStaff    Barber[]         @relation("StaffServices")
}

enum Role {
  CUSTOMER
  OWNER
  RECEPTIONIST
  BARBER
}

enum CustomerType {
  CASUAL
  REGULAR
}

enum AppointmentStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
  NOSHOW
}

enum Status {
  ACTIVE
  COMPLETED
}

enum ServiceCategory {
  SIGNATURE_HAIRCUT
  KIDS_HAIRCUT
  SHAVE
  SCALP_MASSAGE
}

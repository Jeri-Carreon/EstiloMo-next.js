generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation("accounts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Counter {
  id    String @id
  value Int
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  password      String
  firstName     String
  lastName      String
  lockedUntil   DateTime?
  loginAttempts Int       @default(0)
  mobileNumber  String    @db.VarChar(11)
  role          Role      @default(CUSTOMER)
  emailVerified Boolean   @default(false)
  userCode      String    @unique
  isActive      Boolean   @default(true)
  accounts      Account[] @relation("accounts")
  barber        Barber?
  customer      Customer?
  reviews       Review[]
  sessions      Session[]
}

model Customer {
  id            String       @id @default(cuid())
  userId        String?      @unique
  customerCode  String       @unique
  customerType  CustomerType @default(CASUAL)
  firstName     String
  lastName      String
  email         String?      @unique
  mobileNumber  String       @db.VarChar(11)
  loyaltyPoints Int          @default(0)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user         User?         @relation(fields: [userId], references: [id])
  appointments Appointment[]
  loyaltyCards LoyaltyCard[]
  sales        Sale[]
}

model Barber {
  id           String @id @default(cuid())
  barberCode   String @unique
  firstName    String
  lastName     String
  mobileNumber String
  email        String
  userId       String @unique

  user             User             @relation(fields: [userId], references: [id])
  appointments     Appointment[]
  absence          BarberAbsent[]
  schedules        BarberSchedule[]
  assignedServices Service[]        @relation("StaffServices")
  sales            Sale[]
}

model BarberSchedule {
  id        String   @id @default(cuid())
  barberId  String
  dayOfWeek Int
  startTime Int
  endTime   Int
  isDayOff  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
}

model BarberAbsent {
  id        String   @id @default(cuid())
  barberId  String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, date])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
}

model ContactUsMessages {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  message   String?
  createdAt DateTime @default(now())
}

model Review {
  id            String       @id @default(cuid())
  appointmentId String?      @unique
  service       String
  rating        Int
  comment       String?
  status        ReviewStatus @default(PENDING)
  isVisible     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("Review")
}

model Appointment {
  id              String            @id @default(cuid())
  appointmentCode String            @unique
  customerId      String
  serviceId       String
  barberId        String
  saleId          String?
  status          AppointmentStatus @default(PENDING)
  source          AppointmentSource @default(BOOKING)
  appointmentDate DateTime
  startMinutes    Int
  endMinutes      Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  customer           Customer            @relation(fields: [customerId], references: [id])
  service            Service             @relation(fields: [serviceId], references: [id])
  barber             Barber              @relation(fields: [barberId], references: [id])
  sale               Sale?               @relation(fields: [saleId], references: [id], onDelete: SetNull)
  payment            Payment?
  review             Review?
  afterServicePhotos AfterServicePhoto[]

  @@index([customerId])
  @@index([serviceId])
  @@index([barberId])
  @@index([saleId])
}

model AppointmentSetting {
  id                 String   @id @default(cuid())
  bookingCutoffHours Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AfterServicePhoto {
  id            String   @id @default(cuid())
  appointmentId String
  imageUrl      String
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model Sale {
  id          String     @id @default(cuid())
  saleCode    String     @unique
  customerId  String
  barberId    String?
  source      SaleSource @default(WALKIN)
  status      SaleStatus @default(PENDING)
  subtotal    Decimal    @default(0) @db.Decimal(10, 2)
  discount    Decimal    @default(0) @db.Decimal(10, 2)
  totalAmount Decimal    @default(0) @db.Decimal(10, 2)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id])
  barber       Barber?       @relation(fields: [barberId], references: [id])
  items        SaleItem[]
  payment      Payment?
  appointments Appointment[]

  @@index([customerId])
  @@index([barberId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  serviceId String
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([saleId])
  @@index([serviceId])
}

model Payment {
  id            String        @id @default(cuid())
  appointmentId String?       @unique
  saleId        String?       @unique
  paymentCode   String?       @unique
  amount        Decimal       @db.Decimal(10, 2)
  downPayment   Decimal       @default(0) @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(PENDING)
  screenshotUrl String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  sale        Sale?        @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model LoyaltyCard {
  id         String   @id @default(cuid())
  customerId String
  stars      Int      @default(0)
  status     Status   @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model LoyaltyCardSetting {
  id                     String   @id @default(cuid())
  stickersPerTransaction Int      @default(1)
  fiveStickerReward      String   @default("50% Off")
  tenStickerReward       String   @default("100% Off")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model LoyaltyCardActivity {
  id           String   @id @default(cuid())
  customerName String
  message      String
  createdAt    DateTime @default(now())
}

model Service {
  id               String           @id @default(cuid())
  serviceCode      String           @unique
  name             String
  description      String?
  category         ServiceCategory?
  durationMinutes  Int
  price            Decimal          @db.Decimal(10, 2)
  sortOrder        Int              @default(1)
  isAvailable      Boolean          @default(true)
  requiresApproval Boolean          @default(false)
  cancellationFee  Decimal?         @db.Decimal(10, 2)
  totalBookings    Int              @default(0)
  totalRevenue     Decimal          @default(0) @db.Decimal(12, 2)
  isFeatured       Boolean          @default(false)
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  appointments  Appointment[]
  saleItems     SaleItem[]
  assignedStaff Barber[]      @relation("StaffServices")
}

enum ReviewStatus {
  PENDING
  COMPLETED
  REJECTED
  HIDDEN
}

enum PaymentMethod {
  GCASH
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  REJECTED
}

enum SaleSource {
  BOOKING
  WALKIN
}

enum SaleStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum AppointmentSource {
  BOOKING
  WALKIN
}

enum Role {
  CUSTOMER
  OWNER
  RECEPTIONIST
  BARBER
}

enum CustomerType {
  CASUAL
  REGULAR
}

enum AppointmentStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
  NOSHOW
  REJECTED
}

enum Status {
  ACTIVE
  COMPLETED
}

enum ServiceCategory {
  SIGNATURE_HAIRCUT
  KIDS_HAIRCUT
  SHAVE
  SCALP_MASSAGE
}
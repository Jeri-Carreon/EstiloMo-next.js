generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation("accounts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Counter {
  id    String @id
  value Int
}

model User {
  id            String    @id @default(cuid())
  userCode      String    @unique
  email         String?   @unique
  emailVerified Boolean   @default(false)
  image         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  password      String
  role          Role    @default(CUSTOMER)

  lockedUntil   DateTime?
  loginAttempts Int       @default(0)

  firstName     String
  lastName      String
  mobileNumber  String    @db.VarChar(11)

  accounts      Account[] @relation("accounts")
  sessions      Session[]

  reviews       Review[]

  customer      Customer?
  
  services       Service[]  @relation("StaffServices")
}

enum Role {
  CUSTOMER
  OWNER
  RECEPTIONIST
  BARBER
}

model Customer {
  id            String   @id @default(cuid())
  customerCode  String   @unique
  firstName     String?
  lastName      String?
  email         String?  @unique
  mobileNumber  String   @db.VarChar(11)

  customerType  CustomerType @default(CASUAL)

  loyaltyPoints Int @default(0)

  // Optional link to login account
  userId        String? @unique
  user          User? @relation(fields: [userId], references: [id])

  appointments  Appointment[]
  loyaltyCards  LoyaltyCard[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum CustomerType {
  CASUAL
  REGULAR
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
}

model ContactUsMessages {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  message   String?
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  service   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Review")
}

model Appointment {
  id          String   @id @default(cuid())
  scheduledAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])

  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id])
}

enum Status {
  ACTIVE
  COMPLETED
}

model LoyaltyCard {
  id          String   @id @default(cuid())
  stars       Int      @default(0)
  status      Status   @default(ACTIVE)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Service {
  id              String   @id @default(cuid())
  serviceCode     String   @unique
  // Basic Info
  name            String
  description     String?
  category        ServiceCategory?

  // Pricing & Duration
  durationMinutes Int
  price           Decimal  @db.Decimal(10, 2)

  // Availability
  isAvailable     Boolean  @default(true)

  // Staff Assignment (many-to-many with User)
  assignedStaff   User[]   @relation("StaffServices")

  // Scheduling
  bufferBefore    Int      @default(0)
  bufferAfter     Int      @default(0)

  // Customer Rules
  requiresApproval Boolean  @default(false)
  cancellationFee Decimal? @db.Decimal(10, 2)

  // Analytics
  totalBookings   Int      @default(0)
  totalRevenue    Decimal  @default(0) @db.Decimal(12, 2)

  // Status
  isFeatured      Boolean  @default(false)

  // Audit
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  appointments    Appointment[]
}

enum ServiceCategory {
  SIGNATURE_HAIRCUT
  KIDS_HAIRCUT
  SHAVE
  SCALP_MASSAGE
}